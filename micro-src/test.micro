/*
========================================================
Comparison test
========================================================
*/
fn comparison_test(a, b) {
    if (a == b) {
        return 100;
    }

    if (a > b) {
        return 200;
    }

    if (a < b) {
        return 300;
    }

    return 0;
}

/*
========================================================
Loop accumulation test
========================================================
*/
fn sum_to_n(n) {
    let i = 0;
    let sum = 0;

    loop {
        if (i == n) {
            return sum;
        }

        sum = sum + i;
        i = i + 1;
    }
}

/*
========================================================
Nested call test
========================================================
*/
fn nested_calls() {
    return add(
        mul(2, 3),
        sub(
            factorial(4),
            fib(6)
        )
    );
}

/*
========================================================
Large mixed integration test
========================================================
*/
fn run_all_tests() {

    //--------------------------------------------
    // arithmetic
    //--------------------------------------------
    let a1 = add(10, 5);
    let a2 = sub(20, 3);
    let a3 = mul(6, 7);
    let a4 = div(100, 5);

    //--------------------------------------------
    // recursion
    //--------------------------------------------
    let r1 = factorial(5);
    let r2 = fib(8);

    //--------------------------------------------
    // structs
    //--------------------------------------------
    //let pt = make_point(11, 22);
    let s1 = 33;//point_sum(pt);

    //--------------------------------------------
    // arrays
    //--------------------------------------------
    let ar = 0; //array_test();

    //--------------------------------------------
    // comparisons
    //--------------------------------------------
    let c1 = comparison_test(5, 5);
    let c2 = comparison_test(9, 4);
    let c3 = comparison_test(2, 7);

    //--------------------------------------------
    // loops
    //--------------------------------------------
    let l1 = sum_to_n(10);

    //--------------------------------------------
    // nested calls
    //--------------------------------------------
    let n1 = nested_calls();

    //--------------------------------------------
    // final aggregate
    //--------------------------------------------
    return
        a1 +
        a2 +
        a3 +
        a4 +
        r1 +
        r2 +
        s1 +
        ar +
        c1 +
        c2 +
        c3 +
        l1 +
        n1;
}