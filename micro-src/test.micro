/*
========================================================
Micro-C Full Language Stress Test
Tests:
- exports
- functions
- recursion
- arithmetic
- comparisons
- branching
- loops
- nested function calls
- structs
- arrays
- variable assignment
- function parameters
- temporary values
========================================================
*/

export fn main() {
    let result = run_all_tests();
    return result;
}

/*
========================================================
Basic arithmetic
========================================================
*/
fn add(a, b) {
    return a + b;
}

fn sub(a, b) {
    return a - b;
}

fn mul(a, b) {
    let result = 0;
    let i = 0;

    loop {
        if (i == b) {
            return result;
        }

        result = result + a;
        i = i + 1;
    }
}

fn div(a, b) {
    let count = 0;
    let temp = a;

    loop {
        if (temp < b) {
            return count;
        }

        temp = temp - b;
        count = count + 1;
    }
}

/*
========================================================
Recursion test
========================================================
*/
fn factorial(n) {
    if (n == 0) {
        return 1;
    }

    return n * factorial(n - 1);
}

fn fib(n) {
    if (n == 0) {
        return 0;
    }

    if (n == 1) {
        return 1;
    }

    return fib(n - 1) + fib(n - 2);
}

